/** 添加页样式 **/
.page {
  padding: 20rpx;
  padding-bottom: 100rpx;
}

/* 拍照区域 */
.camera-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}
.camera-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 60rpx;
  border: 2rpx dashed #07c160;
  border-radius: 16rpx;
  background: #f0faf4;
  cursor: pointer;
}
.camera-icon {
  font-size: 60rpx;
  margin-bottom: 10rpx;
}
.camera-text {
  font-size: 28rpx;
  color: #07c160;
  font-weight: 500;
}
.ocr-hint {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #ff9500;
}
.ocr-result {
  margin-top: 16rpx;
  padding: 12rpx;
  background: #f0f0f0;
  border-radius: 8rpx;
  width: 100%;
  word-break: break-all;
}
.ocr-raw {
  font-size: 22rpx;
  color: #666;
}

/* 表单区域 */
.form-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}
.form-item {
  margin-bottom: 28rpx;
}
.form-label {
  display: block;
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 10rpx;
}
.form-input {
  width: 100%;
  height: 72rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}
.form-picker {
  width: 100%;
  height: 72rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #333;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-sizing: border-box;
}
.picker-arrow {
  color: #ccc;
  font-size: 36rpx;
}
.form-row {
  display: flex;
  gap: 20rpx;
}
.form-half {
  flex: 1;
}

/* 提交按钮 */
.submit-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #07c160, #06ad56);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 20rpx;
  border: none;
}
.submit-btn[disabled] {
  background: #ccc;
}
