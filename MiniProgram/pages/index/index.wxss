/** 首页样式 **/
.page {
  padding: 20rpx;
  min-height: 100vh;
}

/* 统计栏 */
.stats-bar {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx 0;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}
.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.stat-num {
  font-size: 40rpx;
  font-weight: 700;
  line-height: 1.2;
}
.stat-num.normal { color: #07c160; }
.stat-num.warning { color: #ff9500; }
.stat-num.expired { color: #ff3b30; }
.stat-label {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
}

/* 食品卡片 */
.food-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.food-card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}
.card-left {
  margin-right: 20rpx;
}
.card-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
}
.category-肉类 { background: #ffe0e0; }
.category-蔬菜 { background: #e0f5e0; }
.category-水果 { background: #fff3e0; }
.category-乳制品 { background: #e8f0fe; }
.category-饮料 { background: #e0f0ff; }
.category-调味品 { background: #f5e0f5; }
.category-other { background: #f0f0f0; }

.card-body {
  flex: 1;
  min-width: 0;
}
.card-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}
.card-info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}
.card-date {
  font-size: 24rpx;
  color: #666;
}
.card-quantity {
  font-size: 22rpx;
  color: #999;
}
.card-tags {
  margin-top: 8rpx;
}
.tag {
  display: inline-block;
  font-size: 20rpx;
  color: #666;
  background: #f5f5f5;
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
}

.card-right {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 90rpx;
  margin-left: 16rpx;
}
.days-num {
  font-size: 36rpx;
  font-weight: 700;
}
.days-label {
  font-size: 20rpx;
  margin-top: 4rpx;
}
.status-0 .days-num { color: #07c160; }
.status-0 .days-label { color: #07c160; }
.status-1 .days-num { color: #ff9500; }
.status-1 .days-label { color: #ff9500; }
.status-2 .days-num { color: #ff3b30; }
.status-2 .days-label { color: #ff3b30; }

/* 空状态 */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}
.empty-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}
.empty-text {
  font-size: 32rpx;
  color: #999;
}
.empty-hint {
  font-size: 26rpx;
  color: #ccc;
  margin-top: 10rpx;
}

/* 加载 */
.loading {
  text-align: center;
  padding: 40rpx;
  color: #999;
}
